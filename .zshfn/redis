case $1 in
	start)
		docker_del_stopped redis

		docker run -d \
			--name redis \
			-e REDIS_ARGS="--save 60 1 --loglevel warning --maxmemory 16gb --maxmemory-policy allkeys-lru" \
			-p 6379:6379 \
      -p 8001:8001 \
      -v redisdata:/data \
			redis/redis-stack:latest
		;;
	stop)
		docker container stop redis
		;;
	*)
		echo "Usage: $0 {start|stop}"
		return 1
		;;
esac
