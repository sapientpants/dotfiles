case $1 in
	start)
		docker_del_stopped elasticsearch

		docker run -d \
			--name elasticsearch \
			-p 9200:9200 \
      -p 9300:9300 \
      -e "discovery.type=single-node" \
			elasticsearch:8.15.3
		;;
	stop)
		docker container stop elasticsearch
		;;
	*)
		echo "Usage: $0 {start|stop}"
		return 1
		;;
esac
